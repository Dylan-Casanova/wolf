#!/bin/sh

# Run Pint on staged PHP files before committing
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.php$')

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

echo "Running Pint on staged PHP files..."

# Check if we're in Docker
if docker compose exec -T app echo "" > /dev/null 2>&1; then
    docker compose exec -T app ./vendor/bin/pint $STAGED_FILES
else
    ./vendor/bin/pint $STAGED_FILES
fi

# Re-stage the fixed files
echo "$STAGED_FILES" | xargs git add

exit 0

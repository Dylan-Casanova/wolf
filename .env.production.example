# =============================================================================
# Wolf — Production Environment Variables
# =============================================================================
# Copy this file to .env on your server and fill in real values.
#
# Setup:
#   1. cp .env.production.example .env
#   2. Fill in values marked CHANGE_ME (see comments for how to generate)
#   3. docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
#   4. docker compose exec app php artisan key:generate
#   5. docker compose exec app php artisan migrate --force
# =============================================================================

APP_NAME=Wolf
APP_ENV=production
APP_KEY=
APP_DEBUG=false

# Your domain — used by Caddy for HTTPS and by Laravel for URL generation
# Example: wolf.yourdomain.com
APP_DOMAIN=CHANGE_ME
APP_URL=https://CHANGE_ME

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Database ---
# MySQL runs inside Docker, not exposed to the internet.
# Generate a strong password: openssl rand -base64 24
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=wolf
DB_USERNAME=wolf
DB_PASSWORD=CHANGE_ME

# --- Sessions / Cache / Queues ---
# Redis runs inside Docker, not exposed to the internet.
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- MQTT ---
# Mosquitto runs inside Docker. ESP devices connect on port 1883.
DEVICE_DRIVER=esp32_mqtt
MQTT_HOST=mosquitto
MQTT_PORT=1883

# --- Reverb WebSocket ---
# Generate secrets: openssl rand -hex 16
REVERB_APP_ID=wolf-prod
REVERB_APP_KEY=CHANGE_ME
REVERB_APP_SECRET=CHANGE_ME
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

# Vite variables are baked into the frontend build.
# VITE_REVERB_HOST must be your public domain (browser connects via Caddy).
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=CHANGE_ME
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

VITE_APP_NAME="${APP_NAME}"

# --- Mail ---
# For now, log driver is fine — emails go to storage/logs.
# When ready, switch to smtp and configure your mail provider.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@CHANGE_ME"
MAIL_FROM_NAME="${APP_NAME}"

# --- Telescope ---
# Disabled in production to save memory and DB writes.
TELESCOPE_ENABLED=false
